<mxfile host="app.diagrams.net">
  <diagram name="UML App Gastos">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- INTERFACES -->
        <mxCell id="IAutenticable" value="&lt;&lt;interface&gt;&gt;&#10;IAutenticable&#10;+login()&#10;+logout()&#10;+register()" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="180" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="ICrud" value="&lt;&lt;interface&gt;&gt;&#10;ICrudMovimiento&#10;+crear()&#10;+editar()&#10;+eliminar()&#10;+listar()" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="260" y="40" width="200" height="140" as="geometry"/>
        </mxCell>

        <mxCell id="IGenerador" value="&lt;&lt;interface&gt;&gt;&#10;IGeneradorReportes&#10;+generar()&#10;+exportarPDF()" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="500" y="40" width="200" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="INotificable" value="&lt;&lt;interface&gt;&gt;&#10;INotificable&#10;+enviarNotificacion()" style="shape=rectangle;whiteSpace=wrap;html=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="740" y="40" width="200" height="100" as="geometry"/>
        </mxCell>

        <!-- CLASES PRINCIPALES -->
        <mxCell id="Usuario" value="Usuario&#10;id&#10;nombre&#10;email&#10;password" style="shape=rectangle;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="220" width="180" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="Cuenta" value="Cuenta&#10;id&#10;nombre&#10;saldo" style="shape=rectangle;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="260" y="220" width="180" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="Movimiento" value="Movimiento&#10;id&#10;importe&#10;fecha&#10;estado" style="shape=rectangle;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="220" width="180" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="Gasto" value="Gasto" style="shape=rectangle;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="370" width="120" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="Ingreso" value="Ingreso" style="shape=rectangle;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="640" y="370" width="120" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="Categoria" value="Categoria&#10;id&#10;nombre" style="shape=rectangle;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="740" y="220" width="180" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="Presupuesto" value="Presupuesto&#10;limite&#10;gastado" style="shape=rectangle;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="400" width="180" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="Objetivo" value="ObjetivoAhorro&#10;cantidad&#10;progreso" style="shape=rectangle;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="260" y="400" width="180" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="MetodoPago" value="MetodoPago&#10;tipo&#10;detalle" style="shape=rectangle;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="740" y="370" width="180" height="100" as="geometry"/>
        </mxCell>

        <!-- HERENCIA -->
        <mxCell id="e1" edge="1" parent="1" source="Movimiento" target="Gasto" style="endArrow=block;html=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e2" edge="1" parent="1" source="Movimiento" target="Ingreso" style="endArrow=block;html=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- IMPLEMENTACION INTERFACES -->
        <mxCell id="e3" edge="1" parent="1" source="Usuario" target="IAutenticable" style="dashed=1;endArrow=open;html=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e4" edge="1" parent="1" source="Cuenta" target="ICrud" style="dashed=1;endArrow=open;html=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- RELACIONES -->
        <mxCell id="e5" edge="1" parent="1" source="Usuario" target="Cuenta" style="endArrow=block;html=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e6" edge="1" parent="1" source="Cuenta" target="Movimiento" style="endArrow=block;html=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e7" edge="1" parent="1" source="Categoria" target="Movimiento" style="endArrow=block;html=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e8" edge="1" parent="1" source="Movimiento" target="MetodoPago" style="endArrow=block;html=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e9" edge="1" parent="1" source="Usuario" target="Presupuesto" style="endArrow=block;html=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e10" edge="1" parent="1" source="Usuario" target="Objetivo" style="endArrow=block;html=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>